{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "composite": true,
    "rootDir": ".",
    "outDir": "./.tsbuild/node",
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
