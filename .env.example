# Travel Buddy — Supabase (Slices 53–60)
# Copy to `.env.local` for local development. Never commit secrets.
# Only the publishable anon key belongs in the Vite client.
# Service-role keys must never be used in the browser.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key

# Optional: expected project ref used for target verification (no secrets).
VITE_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
