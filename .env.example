# --- Travel provider integration layer (mock-only until suppliers approved) ---
# Toggle suppliers without code changes: enabled | disabled | pending
# VITE_TRAVEL_PROVIDER_AMADEUS=enabled
# VITE_TRAVEL_PROVIDER_DUFFEL=disabled
# VITE_TRAVEL_PROVIDER_BOOKING_COM=pending
# VITE_TRAVEL_PROVIDER_VIATOR=enabled
# Optional public identifiers only (never put private API secrets in VITE_*):
# VITE_TRAVEL_AMADEUS_CLIENT_ID=
# VITE_TRAVEL_BOOKING_AFFILIATE_ID=
# VITE_TRAVEL_VIATOR_PARTNER_ID=
# VITE_TRAVEL_LIVE_PROXY_ENABLED=false
#
# Server-side only (NOT for Vite / frontend bundles) when live integrations are approved:
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# DUFFEL_ACCESS_TOKEN=
# BOOKING_COM_API_KEY=
